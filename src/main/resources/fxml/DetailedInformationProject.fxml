<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="QUANLINHANSU.controller.DetailedInfoProjectController">
    <children>
        <Label layoutX="210.0" layoutY="20.0" text="CHI TIẾT ĐỘI NGŨ DỰ ÁN" textFill="#1e5d48">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <GridPane hgap="10.0" layoutX="40.0" layoutY="70.0" prefHeight="100.0" prefWidth="620.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="120.0" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="200.0" minWidth="10.0" prefWidth="180.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="120.0" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="200.0" minWidth="10.0" prefWidth="180.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Mã Dự Án:">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Label fx:id="ttctMDA" text="---" GridPane.columnIndex="1" />

                <Label text="Tên Dự Án:" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Label fx:id="ttctTDA" text="---" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Kinh Phí:" GridPane.rowIndex="2">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Label fx:id="ttctKinhPhi" text="---" textFill="#e40d0d" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Ngày Bắt Đầu:" GridPane.columnIndex="2">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Label fx:id="ttctStart" text="---" GridPane.columnIndex="3" />

                <Label text="Ngày Kết Thúc:" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
                <Label fx:id="ttctEnd" text="---" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            </children>
        </GridPane>

        <Label layoutX="40.0" layoutY="185.0" text="Danh sách nhân viên tham gia:" textFill="#333">
            <font><Font name="System Italic" size="14.0" /></font>
        </Label>

        <TableView fx:id="tbTTCTDA" layoutX="40.0" layoutY="210.0" prefHeight="230.0" prefWidth="620.0">
            <columns>
                <TableColumn fx:id="colMNV" prefWidth="120.0" text="Mã Nhân Viên" />
                <TableColumn fx:id="colName" prefWidth="250.0" text="Họ Và Tên" />
                <TableColumn fx:id="colSDT" prefWidth="240.0" text="Số Điện Thoại" />
            </columns>
        </TableView>

        <Button layoutX="300.0" layoutY="455.0" mnemonicParsing="false" onAction="#closeWindow" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #1e5d48; -fx-text-fill: white; -fx-cursor: hand;" text="Đóng" />
    </children>
</AnchorPane>