<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="16" style="-fx-background-color: #F5F5F5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="QUANLINHANSU.controller.DashBoardController">

    <!-- Tiêu đề -->
    <Label alignment="CENTER" prefHeight="30.0" prefWidth="102.0" style="-fx-font-size: 20px; -fx-font-weight: BOLD; -fx-text-fill: #1B3A2D;" text="Trang Chủ" />

    <!-- Hàng thẻ thống kê -->
    <HBox spacing="16">

        <VBox alignment="CENTER_LEFT" prefHeight="90" prefWidth="200" spacing="6" style="-fx-background-color: white; -fx-padding: 16;                      -fx-background-radius: 8;                      -fx-effect: dropshadow(gaussian, #00000015, 6, 0, 0, 2);">
            <Label style="-fx-text-fill: #607D8B; -fx-font-size: 12px;" text="👤  Tổng Nhân Viên" />
            <Label fx:id="lblTongNV" style="-fx-font-size: 28px; -fx-font-weight: BOLD; -fx-text-fill: #1B3A2D;" text="0" />
        </VBox>

        <VBox alignment="CENTER_LEFT" prefHeight="90" prefWidth="200" spacing="6" style="-fx-background-color: white; -fx-padding: 16;                      -fx-background-radius: 8;                      -fx-effect: dropshadow(gaussian, #00000015, 6, 0, 0, 2);">
            <Label style="-fx-text-fill: #607D8B; -fx-font-size: 12px;" text="✅  Đang Làm Việc" />
            <Label fx:id="lblDangLam" style="-fx-font-size: 28px; -fx-font-weight: BOLD; -fx-text-fill: #2E7D32;" text="0" />
        </VBox>

        <VBox alignment="CENTER_LEFT" prefHeight="90" prefWidth="200" spacing="6" style="-fx-background-color: white; -fx-padding: 16;                      -fx-background-radius: 8;                      -fx-effect: dropshadow(gaussian, #00000015, 6, 0, 0, 2);">
            <Label style="-fx-text-fill: #607D8B; -fx-font-size: 12px;" text="🏢  Phòng Ban" />
            <Label fx:id="lblTongPB" style="-fx-font-size: 28px; -fx-font-weight: BOLD; -fx-text-fill: #1565C0;" text="0" />
        </VBox>

        <VBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="210.0" spacing="6" style="-fx-background-color: white; -fx-padding: 16;                      -fx-background-radius: 8;                      -fx-effect: dropshadow(gaussian, #00000015, 6, 0, 0, 2);">
            <Label style="-fx-text-fill: #607D8B; -fx-font-size: 12px;" text="Dự Án" />
            <Label fx:id="lblTongDA" style="-fx-font-size: 28px; -fx-font-weight: BOLD; -fx-text-fill: #E65100;" text="0" />
        </VBox>

    </HBox>

    <!-- Hàng bảng -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Chấm công hôm nay -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 16;                      -fx-background-radius: 8;                      -fx-effect: dropshadow(gaussian, #00000015, 6, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 14px; -fx-font-weight: BOLD; -fx-text-fill: #1B3A2D;" text="🕐  Chấm Công Hôm Nay" />
            <TableView fx:id="tableChamCongHomNay" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colMaNV" prefWidth="80" text="Mã NV" />
                    <TableColumn fx:id="colHoTen" prefWidth="234.40000915527344" text="Họ Tên" />
                    <TableColumn fx:id="colGioVao" minWidth="8.0" prefWidth="105.5999755859375" text="Giờ Vào" />
                    <TableColumn fx:id="colGioRa" prefWidth="107.199951171875" text="Giờ Ra" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #90A4AE;" text="Chưa có dữ liệu chấm công hôm nay" />
                </placeholder>
            </TableView>
        </VBox>

        <!-- HĐ sắp hết hạn -->


    </HBox>

</VBox>
