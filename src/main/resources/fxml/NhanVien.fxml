<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="QUANLINHANSU.controller.NhanVienController"
      spacing="10" style="-fx-background-color: white; -fx-padding: 16;">

    <!-- ===== THANH TÌM KIẾM ===== -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" promptText="Search"
                   prefWidth="300" prefHeight="30"/>
        <Button text="Tìm Kiếm" onAction="#timKiem"
                prefHeight="30"
                style="-fx-background-color: #607D8B; -fx-text-fill: white;
                       -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>

    <!-- ===== BẢNG DANH SÁCH ===== -->
    <TableView fx:id="tableNhanVien" prefHeight="280"
               onMouseClicked="#chonNhanVien">
        <columns>
            <TableColumn fx:id="colMaNV"       text="ID"             prefWidth="80"/>
            <TableColumn fx:id="colHoTen"      text="Họ Tên"         prefWidth="160"/>
            <TableColumn fx:id="colGioiTinh"   text="Giới Tính"      prefWidth="80"/>
            <TableColumn fx:id="colNgaySinh"   text="Ngày Sinh"      prefWidth="110"/>
            <TableColumn fx:id="colNgayVaoLam" text="Ngày Vào Làm"   prefWidth="110"/>
            <TableColumn fx:id="colTrangThai"  text="Trạng Thái"     prefWidth="100"/>
            <TableColumn fx:id="colSdt"        text="Số Điện Thoại"  prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="Không có dữ liệu" style="-fx-text-fill: #90A4AE;"/>
        </placeholder>
    </TableView>

    <!-- ===== FORM NHẬP ===== -->
    <GridPane hgap="12" vgap="10" style="-fx-padding: 10 0 0 0;">
        <columnConstraints>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints prefWidth="200"/>
            <ColumnConstraints minWidth="110" halignment="RIGHT"/>
            <ColumnConstraints prefWidth="200"/>
            <ColumnConstraints prefWidth="120"/>
        </columnConstraints>

        <!-- Hàng 1 -->
        <Label text="Mã Nhân Viên:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtMaNV" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Ngày Vào Làm:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <DatePicker fx:id="dpNgayVaoLam" GridPane.columnIndex="3" GridPane.rowIndex="0"
                    prefWidth="200"/>

        <!-- Nút Thêm + Sửa -->
        <VBox spacing="8" GridPane.columnIndex="4" GridPane.rowIndex="0"
              GridPane.rowSpan="2" alignment="CENTER">
            <Button text="Thêm" onAction="#them" prefWidth="100" prefHeight="32"
                    style="-fx-background-color: #455A64; -fx-text-fill: white;
                           -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="Sửa" onAction="#sua" prefWidth="100" prefHeight="32"
                    style="-fx-background-color: #455A64; -fx-text-fill: white;
                           -fx-background-radius: 4; -fx-cursor: hand;"/>
        </VBox>

        <!-- Hàng 2 -->
        <Label text="Họ Tên:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtHoTen" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Trạng Thái:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <ComboBox fx:id="cbTrangThai" prefWidth="200"
                  GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <!-- Hàng 3 -->
        <Label text="Giới Tính:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cbGioiTinh" prefWidth="200"
                  GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Số Điện Thoại:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <TextField fx:id="txtSdt" GridPane.columnIndex="3" GridPane.rowIndex="2"/>

        <!-- Nút Xóa + Làm sạch -->
        <VBox spacing="8" GridPane.columnIndex="4" GridPane.rowIndex="2"
              GridPane.rowSpan="2" alignment="CENTER">
            <Button text="Xóa" onAction="#xoa" prefWidth="100" prefHeight="32"
                    style="-fx-background-color: #455A64; -fx-text-fill: white;
                           -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="Làm sạch" onAction="#lamSach" prefWidth="100" prefHeight="32"
                    style="-fx-background-color: #455A64; -fx-text-fill: white;
                           -fx-background-radius: 4; -fx-cursor: hand;"/>
        </VBox>

        <!-- Hàng 4 -->
        <Label text="Ngày Sinh:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <DatePicker fx:id="dpNgaySinh" GridPane.columnIndex="1" GridPane.rowIndex="3"
                    prefWidth="200"/>

        <Label text="Địa Chỉ:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        <TextField fx:id="txtDiaChi" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

        <!-- Hàng 5 -->
        <Label text="CCCD:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txtCccd" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Email:" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
        <TextField fx:id="txtEmail" GridPane.columnIndex="3" GridPane.rowIndex="4"/>

        <!-- Hàng 6 -->
        <Label text="Phòng Ban:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <ComboBox fx:id="cbPhongBan" prefWidth="200"
                  GridPane.columnIndex="1" GridPane.rowIndex="5"/>

    </GridPane>

</VBox>
